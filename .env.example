# Environment variables for deployment
# Copy this file to .env and fill in the values

# Your wallet's private key (without 0x prefix) for deployment transactions
PRIVATE_KEY=your_private_key_here

# WETH address on Robinhood Chain (mainnet or testnet)
# For mainnet: you can find the WETH address on Robinhood Chain docs or block explorer
# For testnet: use the testnet WETH address
WETH_ADDRESS=your_weth_address_here

# RPC URL for the network you are deploying to (testnet or mainnet)
# Example for testnet: https://rpc.testnet.chain.robinhood.com
# Example for mainnet: https://rpc.mainnet.chain.robinhood.com
# You can also use Alchemy or other RPC providers
RPC_URL=your_rpc_url_here

# Etherscan/Blockscout API key for verification (if using Blockscout explorer)
# For Robinhood Chain testnet, the explorer is https://explorer.testnet.chain.robinhood.com
# You can leave this empty if not verifying, but set it if you want to verify.
BLOCKSCOUT_API_KEY=your_blockscout_api_key_here