# Copy to .env and fill in before deploying.

PRIVATE_KEY=your_private_key_here
RPC_URL=https://rpc.testnet.chain.robinhood.com
WETH_ADDRESS=your_weth_address_here

# Optional: reuse an existing v4 PoolManager instead of deploying a new one.
# POOL_MANAGER=0x...

# Pool defaults used by DeployInvesting manifest and DeployPool.s.sol
POOL_FEE=3000
TICK_SPACING=60

# Blockscout verification (optional)
BLOCKSCOUT_API_KEY=
